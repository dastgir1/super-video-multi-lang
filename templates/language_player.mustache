{{!
    @template mod_supervideo/language_player

    Example context (json):
    {
        "uniqueid": "sv-42",
        "showswitcher": true,
        "languages": [
            {"lang": "en", "langname": "English", "selected": true},
            {"lang": "es", "langname": "Español", "selected": false}
        ],
        "items": [
            {"lang": "en", "player": "<div>...</div>", "description": "<p>...</p>", "selected": true}
        ]
    }
}}
<div class="supervideo-language-player" id="{{uniqueid}}" data-supervideo-language-player="1">
    {{#showswitcher}}
        <div class="supervideo-language-switcher form-inline mb-2">
            <label for="{{uniqueid}}-select" class="mr-2">{{#str}}languageswitcher, mod_supervideo{{/str}}</label>
            <select id="{{uniqueid}}-select" class="form-control custom-select supervideo-language-select">
                {{#languages}}
                    <option value="{{lang}}" {{#selected}}selected="selected"{{/selected}}>{{langname}}</option>
                {{/languages}}
            </select>
        </div>
    {{/showswitcher}}

    {{#items}}
        <div class="supervideo-language-item {{^selected}}supervideo-hidden{{/selected}}"
             data-supervideo-lang="{{lang}}"
             {{^selected}}style="display:none;"{{/selected}}>
            <div class="supervideo-language-item-player">{{{player}}}</div>
            {{#description}}
                <div class="supervideo-language-item-description mt-2">{{{description}}}</div>
            {{/description}}
        </div>
    {{/items}}
</div>
